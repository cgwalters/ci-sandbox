# Containerfile for composefs-rs dev images
#
# Builds a container image containing just cfsctl, published to
# ghcr.io/composefs/dev-composefs-rs on every push to main.
# Used by the upgrade integration test to verify cross-version
# repository compatibility.
#
# Build:
#   podman build -f ci/Containerfile.dev --build-arg base_image=... -t dev-composefs-rs .

ARG base_image=quay.io/centos-bootc/centos-bootc:stream10

# -- source snapshot --
FROM scratch AS src
COPY . /src

# -- build stage --
FROM ${base_image} AS build

COPY --from=src /src/contrib /src/contrib
RUN /src/contrib/packaging/install-build-deps.sh

COPY --from=src /src /src
WORKDIR /src

RUN --mount=type=cache,target=/src/target \
    --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo fetch

RUN --network=none \
    --mount=type=cache,target=/src/target \
    --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo build --release -p cfsctl && \
    cp /src/target/release/cfsctl /usr/bin/cfsctl

# -- final image (just cfsctl, no test harness) --
FROM ${base_image}
COPY --from=build /usr/bin/cfsctl /usr/bin/cfsctl
