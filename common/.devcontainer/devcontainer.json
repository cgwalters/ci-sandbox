{
  "name": "bootc-devenv-debian",
  "image": "ghcr.io/bootc-dev/devenv-debian",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "golang.Go"
      ]
    },
    "devaipod": {
      // Signal to devaipod to apply minimal nested-container privileges
      // (unmask=/proc/*, SYS_ADMIN, etc.) instead of full --privileged.
      "nestedContainers": true
    }
  },
  "features": {},
  // Needed for nested containers (podman-in-podman, VMs).
  // devaipod will use more targeted privileges when it sees
  // customizations.devaipod.nestedContainers above.
  "privileged": true,
  "runArgs": [
    "--device", "/dev/net/tun"
  ],
  "postCreateCommand": {
    "devenv-init": "sudo /usr/local/bin/devenv-init.sh"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/usr/local/cargo/bin"
  }
}
